3️⃣ AJAX Script

home.blade.php ke bottom me add karo:

<script>

document.getElementById("applyFilters").addEventListener("click", function(){

let category = document.getElementById("filter-category").value;
let price = document.getElementById("filter-price").value;
let rating = document.getElementById("filter-rating").value;

fetch("{{ route('filter.products') }}", {

method: "POST",

headers: {

"Content-Type": "application/json",
"X-CSRF-TOKEN": document.querySelector('meta[name="csrf-token"]').getAttribute("content")

},

body: JSON.stringify({

category: category,
price: price,
rating: rating

})

})

.then(res => res.text())

.then(data => {

document.getElementById("product-grid").innerHTML = data;

});

});

</script>
4️⃣ Controller Filter

Controller me:

public function filterProducts(Request $request)
{

$query = Product::query();

if($request->category){
$query->where('category_id',$request->category);
}

if($request->rating){
$query->where('rating','>=',$request->rating);
}

if($request->price){

$price = explode('-',$request->price);

$query->whereBetween('price',[$price[0],$price[1]]);

}

$products = $query->get();

return view('partials.filtered-products',compact('products'));

}
